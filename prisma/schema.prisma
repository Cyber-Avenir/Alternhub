generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── USER ────────────────────────────────────────────────────────────────────
// role: "STUDENT" | "RECRUTEUR" | "ADMIN"
// searchStatus: "SEARCHING" | "IN_ALTERNANCE" | "GRADUATED"  (students only)
// subscriptionTier: "FREE" | "PRO" | "PREMIUM"

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             String    @default("STUDENT")
  searchStatus     String    @default("SEARCHING")
  subscriptionTier String    @default("FREE")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Student
  profile          Profile?
  missions         Mission[]
  skills           UserSkill[]
  candidatures     Candidature[]
  careerPaths      CareerPath[]

  // Recruiter
  recruteurProfile RecruteurProfile?
  offres           Offre[]

  // Shared
  accounts         Account[]
  sessions         Session[]
}

// ─── STUDENT PROFILE ─────────────────────────────────────────────────────────
model Profile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio             String?
  school          String?
  ecoleId         String?
  ecole           Ecole?    @relation(fields: [ecoleId], references: [id])
  company         String?
  position        String?
  startDate       DateTime?
  endDate         DateTime?
  linkedinUrl     String?
  githubUrl       String?
  portfolioUrl    String?
  phone           String?
  location        String?
  // Search availability
  searchType      String?   // "ALTERNANCE" | "STAGE"
  searchStartDate DateTime?
  searchEndDate   DateTime?
  // Documents
  cvUrl           String?   // uploaded CV file path
  schoolOfferUrl  String?   // school convention PDF/PPTX path
  motivationLetter String?  // rich text motivation letter
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── RECRUITER PROFILE ───────────────────────────────────────────────────────
model RecruteurProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName      String
  companySize      String?
  industry         String?
  companyLogoUrl   String?
  companyWebsite   String?
  companyLinkedin  String?
  siret            String?
  bio              String?
  phone            String?
  location         String?
  offreQuota       Int       @default(3)
  cvViewQuota      Int       @default(10)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ─── ECOLE ───────────────────────────────────────────────────────────────────
model Ecole {
  id              String    @id @default(cuid())
  name            String    @unique
  slug            String?   @unique
  city            String?
  region          String?
  type            String?   // "GRANDE_ECOLE" | "UNIVERSITE" | "CFA" | "BTS" | "MASTER"
  category        String?   // "INFORMATIQUE" | "FINANCE" | "COMMERCE" | "DESIGN" | "INGENIERIE"
  logoUrl         String?
  website         String?
  phone           String?
  email           String?
  description     String?
  tags            String    @default("[]")  // JSON array of tags
  specialities    String    @default("[]")  // JSON array
  successRate     Float?    // % diplômés
  alternanceRate  Float?    // % étudiants en alternance
  employmentRate  Float?    // % emploi 6 mois après
  avgSalary       String?   // salaire moyen à la sortie
  tuitionFee      String?
  duration        String?   // "3 ans", "5 ans"
  levels          String    @default("[]")  // ["BAC+2", "BAC+3", "BAC+5"]
  isActive        Boolean   @default(true)
  isPremium       Boolean   @default(false) // full info requires subscription
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  profiles        Profile[]
  offreTargets    OffreEcole[]
}

// ─── MISSION (renamed conceptually to "Expériences") ─────────────────────────
model Mission {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String    @default("IN_PROGRESS")
  priority    String    @default("MEDIUM")
  startDate   DateTime?
  endDate     DateTime?
  impact      String?
  tags        String    @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── CAREER PATH ─────────────────────────────────────────────────────────────
model CareerPath {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  company     String?
  role        String?
  type        String    @default("ALTERNANCE") // "ALTERNANCE" | "STAGE" | "CDI" | "PROJET"
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean   @default(false)
  description String?
  skills      String    @default("[]") // JSON array of skill names
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── CANDIDATURE (student side tracker) ──────────────────────────────────────
model Candidature {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      String
  role         String
  location     String?
  contractType String    @default("ALTERNANCE")
  status       String    @default("WISHLIST")
  appliedAt    DateTime?
  source       String?
  url          String?
  salary       String?
  notes        String?
  contactName  String?
  contactEmail String?
  reminderAt   DateTime?
  lastActionAt DateTime  @default(now())
  matchScore   Int?
  offreId      String?   // optional link to an Offre
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ─── OFFRE (recruiter job posting) ───────────────────────────────────────────
model Offre {
  id            String       @id @default(cuid())
  recruteurId   String
  recruteur     User         @relation(fields: [recruteurId], references: [id], onDelete: Cascade)
  title         String
  description   String
  contractType  String       @default("ALTERNANCE")
  location      String?
  remote        Boolean      @default(false)
  salary        String?
  startDate     DateTime?
  duration      String?
  requiredLevel String?      // "BAC+2" | "BAC+3" | "BAC+5"
  status        String       @default("PUBLISHED")
  viewCount     Int          @default(0)
  tags          String       @default("[]")  // JSON array of skill/keyword tags
  skills        OffreSkill[]
  targetEcoles  OffreEcole[]
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// ─── OFFRE SKILLS (tags for matching) ────────────────────────────────────────
model OffreSkill {
  id       String @id @default(cuid())
  offreId  String
  offre    Offre  @relation(fields: [offreId], references: [id], onDelete: Cascade)
  skillId  String
  skill    Skill  @relation(fields: [skillId], references: [id])
  required Boolean @default(true)
  weight   Int     @default(1) // 1-3

  @@unique([offreId, skillId])
}

// ─── OFFRE x ECOLE ───────────────────────────────────────────────────────────
model OffreEcole {
  id      String @id @default(cuid())
  offreId String
  offre   Offre  @relation(fields: [offreId], references: [id], onDelete: Cascade)
  ecoleId String
  ecole   Ecole  @relation(fields: [ecoleId], references: [id])

  @@unique([offreId, ecoleId])
}

// ─── SKILL ───────────────────────────────────────────────────────────────────
model Skill {
  id       String       @id @default(cuid())
  name     String       @unique
  category String
  icon     String?
  slug     String?      @unique
  users    UserSkill[]
  offres   OffreSkill[]
}

model UserSkill {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId   String
  skill     Skill    @relation(fields: [skillId], references: [id])
  level     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, skillId])
}

// ─── BONS PLANS & AIDES ──────────────────────────────────────────────────────
model BonPlan {
  id            String    @id @default(cuid())
  title         String
  description   String
  category      String
  discount      String?
  originalPrice String?
  finalPrice    String?
  url           String
  source        String
  imageUrl      String?
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  scrapedAt     DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Aide {
  id          String    @id @default(cuid())
  title       String
  description String
  organisme   String
  amount      String?
  category    String
  eligibility String?
  url         String
  isActive    Boolean   @default(true)
  deadline    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── AUTH (NextAuth) ──────────────────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
